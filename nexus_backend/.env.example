# ──────────────────────────────────────────────
# Nexus Backend — Environment Variables
# Copy to .env and fill in your values.
# ──────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://nexus:nexus@db:5432/nexus

# JWT
SECRET_KEY=change-me-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin seed (created on first startup)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=admin
FIRST_ADMIN_EMAIL=admin@nexus.local

# ownCloud 10 (default storage)
OWNCLOUD_URL=http://owncloud:8080
OWNCLOUD_USERNAME=admin
OWNCLOUD_PASSWORD=admin

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# File upload
MAX_UPLOAD_SIZE_MB=100

# AI / RAG — Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
CHROMA_PERSIST_DIR=./chroma_data