# ─────────────────────────────────────────────────────────
# Nexus — Root .gitignore
# ─────────────────────────────────────────────────────────

# ── Environment variables ──────────────────────────────
.env
.env.*
!.env.example

# ── Python ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ───────────────────────────────
.venv/
venv/
ENV/

# ── Node.js ────────────────────────────────────────────
node_modules/

# ── Next.js ────────────────────────────────────────────
.next/
out/

# ── Build output ───────────────────────────────────────
build/
*.tsbuildinfo
next-env.d.ts

# ── Testing ────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
coverage/

# ── IDE ────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker ─────────────────────────────────────────────
docker-compose.override.yml

# ── Data / runtime ─────────────────────────────────────
chroma_data/
*.db
*.sqlite3

# ── Debug logs ─────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Misc ───────────────────────────────────────────────
*.pem
.vercel
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions